{
  "name": "nuxt-template",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:reset": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$paths = @('.nuxt', 'node_modules\\.cache\\vite', 'node_modules\\.cache\\nuxt'); $paths | Where-Object { Test-Path -LiteralPath $_ } | ForEach-Object { Remove-Item -LiteralPath $_ -Recurse -Force }\" && pnpm dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint app server test nuxt.config.ts drizzle.config.ts eslint.config.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.1",
    "@nihilapp/diceroll-v3": "^3.0.5",
    "@tanstack/vue-query": "^5.101.4",
    "@tanstack/vue-query-devtools": "^6.1.38",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "luxon": "^3.7.2",
    "nuxt": "^4.5.0",
    "postgres": "^3.4.9",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.1",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.3",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.11",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "happy-dom": "^20.11.1",
    "tailwindcss": "^4.3.3",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.8"
  }
}
